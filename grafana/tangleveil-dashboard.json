{
  "title": "Tangleveil",
  "uid": "tangleveil",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "source",
        "type": "query",
        "label": "Source",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(corescope_relay_packets_total, source)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Analyzers connected",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(corescope_relay_source_connected)",
          "legendFormat": "connected",
          "refId": "A"
        },
        {
          "expr": "count(corescope_relay_source_connected)",
          "legendFormat": "total",
          "refId": "B"
        }
      ],
      "options": {
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Packets / sec (total)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(corescope_relay_packets_total[1m]))", "refId": "A" }
      ],
      "options": {
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": { "defaults": { "unit": "pps", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bandwidth (total)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(corescope_relay_bytes_total[1m])) * 8", "refId": "A" }
      ],
      "options": {
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reconnects (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(corescope_relay_reconnects_total[1h]))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Errors (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(increase(corescope_relay_source_errors_total[1h]))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Process uptime",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "time() - process_start_time_seconds", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },

    { "id": 101, "type": "row", "title": "Per-source throughput", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Packets / sec by source",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (source) (rate(corescope_relay_packets_total{source=~\"$source\"}[1m]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Bandwidth by source",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (source) (rate(corescope_relay_bytes_total{source=~\"$source\"}[1m])) * 8",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },

    { "id": 102, "type": "row", "title": "Connection health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },
    {
      "id": 20,
      "type": "state-timeline",
      "title": "Source connected (1 = connected, 0 = not)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "corescope_relay_source_connected{source=~\"$source\"}",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "down", "color": "red" }, "1": { "text": "up", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Seconds since last packet per source",
      "description": "Flags analyzers that are connected but have gone quiet.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "time() - corescope_relay_last_packet_timestamp_seconds{source=~\"$source\"}",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Reconnects / errors per source (rate, 5m)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (source) (rate(corescope_relay_reconnects_total{source=~\"$source\"}[5m]))",
          "legendFormat": "{{source}} reconnects",
          "refId": "A"
        },
        {
          "expr": "sum by (source) (rate(corescope_relay_source_errors_total{source=~\"$source\"}[5m]))",
          "legendFormat": "{{source}} errors",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },

    { "id": 103, "type": "row", "title": "Process", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 } },
    {
      "id": 30,
      "type": "timeseries",
      "title": "CPU usage",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[1m]) * 100", "legendFormat": "cpu", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 }, "overrides": [] }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Resident memory",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "rss", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Open file descriptors",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "process_open_fds", "legendFormat": "open", "refId": "A" },
        { "expr": "process_max_fds", "legendFormat": "max", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ]
}
